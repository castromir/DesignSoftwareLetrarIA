# Configurações de Ambiente - Letrar IA Backend

# Database
# Quando usar Docker, a porta será 55432
DATABASE_URL=postgresql+asyncpg://letrarIA:123@localhost:55432/letraria_db

# Security
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=["http://localhost:3100", "http://localhost:5174"]

# Environment
ENVIRONMENT=development
DEBUG=true

