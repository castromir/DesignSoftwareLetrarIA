# Configurações de Ambiente - Letrar IA Backend

# Database
# Quando usar Docker, a porta será 55432
DATABASE_URL=postgresql+asyncpg://user:password@localhost:55432/letraria_db

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=["http://localhost:3100", "http://localhost:5174"]

# Environment
ENVIRONMENT=development
DEBUG=true

# Google OAuth (Opcional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Storage (S3/MinIO para arquivos de áudio)
STORAGE_TYPE=local
STORAGE_BUCKET_NAME=letraria-recordings
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# AI Service (Futuro - integração com serviço de análise de áudio)
AI_SERVICE_URL=
AI_SERVICE_API_KEY=

