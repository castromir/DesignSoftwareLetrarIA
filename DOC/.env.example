# =============================================================
# Letrar IA — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# cp .env.example .env
# =============================================================

# -------------------------------------------------------------
# PostgreSQL
# -------------------------------------------------------------
POSTGRES_USER=letraria_user
POSTGRES_PASSWORD=letraria_password
POSTGRES_DB=letraria_db
POSTGRES_PORT=55432           # Porta exposta no host

# -------------------------------------------------------------
# Backend (FastAPI)
# -------------------------------------------------------------
BACKEND_PORT=8888             # Porta exposta no host
SECRET_KEY=troque-por-uma-chave-segura
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=["http://localhost:5174","http://127.0.0.1:5174"]

# -------------------------------------------------------------
# Nginx (HTTPS com certificado autoassinado)
# -------------------------------------------------------------
VM_HOST=192.168.1.100         # IP ou domínio da VM (usado no certificado SSL)

# -------------------------------------------------------------
# MinIO (armazenamento de áudio)
# -------------------------------------------------------------
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin   # Mínimo 8 caracteres
MINIO_BUCKET=letraria-recordings
MINIO_USE_SSL=false
MINIO_PORT=9002               # API MinIO exposta no host
MINIO_CONSOLE_PORT=9003       # Console web MinIO exposta no host

# -------------------------------------------------------------
# Provider de IA (gemini | ollama)
# -------------------------------------------------------------
AI_PROVIDER=gemini            # Troque para "ollama" para usar Ollama local

# Google Gemini (usado quando AI_PROVIDER=gemini)
GOOGLE_GENAI_API_KEY=sua-chave-aqui
GOOGLE_GENAI_MODEL=gemini-2.5-flash

# Ollama (usado quando AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://gpu-l40s-1.w3b.inf:11434
OLLAMA_MODEL=llama3.2

# -------------------------------------------------------------
# Whisper (transcrição de áudio)
# -------------------------------------------------------------
WHISPER_MODEL_SIZE=base       # tiny | base | small | medium | large
